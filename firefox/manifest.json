{
  "name": "__MSG_app_name__",
  "short_name": "uSozluk",
  "description": "__MSG_app_description__",
  "version": "2.0.0.0",
  "default_locale": "tr",
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "usozluk@berkaygediz",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "host_permissions": [
    "*://soz.lk/*"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "*://eksisozluk.com/*",
        "*://*.eksisozluk.com/*",
        "*://eksisozluk.net/*",
        "*://eksisozluk.org/*",
        "*://eksisozluk2023.com/*",
        "*://eksisozluk2024.com/*",
        "*://eksisozluk2025.com/*",
        "*://eksisozluk1923.com/*",
        "*://eksi.is/*",
        "*://eksi.so/*",
        "*://soz.lk/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "uSozluk",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "homepage_url": "https://github.com/berkaygediz/uSozluk"
}